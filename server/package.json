{
  "name": "financial-app-server",
  "private": true,
  "version": "0.1.0",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "start:prod": "node scripts/run-with-env.js .env.prod node src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:generate:prod": "node scripts/run-with-env.js .env.prod prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:validate:prod": "node scripts/run-with-env.js .env.prod prisma validate",
    "db:backup": "node scripts/backup-db.js .env manual",
    "db:backup:dev": "node scripts/backup-db.js .env dev",
    "db:backup:prod": "node scripts/backup-db.js .env.prod prod",
    "db:exec:prod": "node scripts/run-with-env.js .env.prod npx prisma db execute --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
