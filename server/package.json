{
  "name": "financial-app-server",
  "private": true,
  "version": "0.1.0",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "dev:test": "node scripts/run-with-env.js .env.test node --watch src/index.js",
    "start:test": "node scripts/run-with-env.js .env.test node src/index.js",
    "prisma:generate:test": "node scripts/run-with-env.js .env.test prisma generate",
    "prisma:validate:test": "node scripts/run-with-env.js .env.test prisma validate",
    "db:test:init": "node scripts/run-with-env.js .env.test npx prisma db execute --file prisma/init.sql --schema prisma/schema.prisma",
    "prisma:seed:test": "node scripts/run-with-env.js .env.test tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
